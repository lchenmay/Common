	  <Compile Include="SD\Json.fs" />
	  <Compile Include="SD\Bin.fs" />
	  <Compile Include="SD\Crypto.fs" />
	  <Compile Include="OS\FileSys.fs" />
	  <Compile Include="OS\Log.fs" />
	  <Compile Include="Measures.fs" />
	  <Compile Include="OS\OS.fs" />
	  <Compile Include="OS\Reflection.fs" />
	  <Compile Include="OS\Bash.fs" />
	  <Compile Include="Network\Diff.fs" />
	  <Compile Include="Network\HtmlFilter.fs" />
	  <Compile Include="Network\Tcp.fs" />
	  <Compile Include="Network\Http.fs" />
	  <Compile Include="Network\TcpServer.fs" />
	  <Compile Include="Network\HttpServer.fs" />
	  <Compile Include="Network\HttpClient.fs" />
	  <Compile Include="Network\Html.fs" />
	  <Compile Include="Network\Browser.fs" />
	  <Compile Include="Network\WebSocket.fs" />
	  <Compile Include="DB\Raven.fs" />
	  <Compile Include="DB\Db.fs" />
    <Compile Include="DB\DbQuery.fs" />
    <Compile Include="DB\DbTx.fs" />
    <Compile Include="DB\DbBackup.fs" />
